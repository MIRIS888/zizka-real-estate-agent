# Demo MVP works without Gemini for the 6 prepared scenarios.
# Add Gemini only for free-form planning beyond the deterministic demo tools.
GEMINI_API_KEY=
# Supported models: gemini-3.5-flash (recommended), gemini-2.5-flash (fallback).
# Gemini 3.5 Flash requires thoughtSignature propagation — handled automatically in run-agent.ts.
# If the primary model fails, the agent automatically falls back to gemini-2.5-flash.
GEMINI_MODEL=gemini-3.5-flash

# local = deterministic in-repo seed data. supabase = live Supabase tables.
DATA_SOURCE=local

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DEFAULT_ORGANIZATION_ID=

# Vercel cron / n8n webhook protection.
CRON_SECRET=
N8N_WEBHOOK_SECRET=
N8N_DAILY_REPORT_WEBHOOK_URL=

# Optional Google Calendar/Gmail integration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Optional live market search. Without this, market monitoring uses mock data.
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev/v2
